		<meta itemprop="mainEntityOfPage" content="https://thesefootballtimes.co/2017/10/31/cafu-the-born-winner-who-became-the-most-complete-full-back-of-his-time/">
		<span class="vcard author" itemprop="author" content="Karan Tejwani">
			<span class="fn">Karan Tejwani</span>
		</span>
		<time class="time publised entry-date" datetime="2017-10-31T01:00:03+00:00" itemprop="datePublished" content="2017-10-31T01:00:03+00:00">31/10/2017</time>
		<meta itemprop="dateModified" class="updated" content="2018-07-25T02:35:19+01:00">
		<span itemprop="publisher" itemscope itemtype="https://schema.org/Organization">
